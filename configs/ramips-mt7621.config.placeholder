# ramips-mt7621 平台配置占位符
# 使用方式：在本地 OpenWrt 编译环境中运行 make menuconfig，
# 选择平台和所需软件包后，执行 ./scripts/diffconfig 导出配置，替换本文件内容。
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_mi-router-ax3000t=y
# 以下为常见配置示例（取消注释即可启用）
# CONFIG_PACKAGE_luci=y
# CONFIG_PACKAGE_luci-app-acctl=y
