# ipq40xx 平台配置占位符
# 使用方式：在本地 OpenWrt 编译环境中运行 make menuconfig，
# 选择平台和所需软件包后，执行 ./scripts/diffconfig 导出配置，替换本文件内容。
CONFIG_TARGET_ipq40xx=y
CONFIG_TARGET_ipq40xx_DEVICE_generic=y
# 以下为常见配置示例（取消注释即可启用）
# CONFIG_PACKAGE_luci=y
# CONFIG_PACKAGE_luci-app-acctl=y

# AP4220配置
CONFIG_TARGET_ipq40xx=y
CONFIG_TARGET_ipq40xx_generic=y
CONFIG_TARGET_ipq40xx_generic_DEVICE_alibaba_ap4220-128m=y

# 主机名称
CONFIG_DEFAULT_HOSTNAME="AP4220"

# wireguard软件包
# CONFIG_PACKAGE_kmod-wireguard=y
# CONFIG_PACKAGE_wireguard-tools=y
# CONFIG_PACKAGE_luci-proto-wireguard=y

# AC-AP软件包
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-acctl=y
